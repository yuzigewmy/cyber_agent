# Optional LLM provider. The app has a deterministic local fallback for demos.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Optional public intelligence APIs.
NVD_API_KEY=
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
FIRST_EPSS_URL=https://api.first.org/data/v1/epss

# Optional vector store path.
CHROMA_PERSIST_DIR=.chroma

# Demo web login. Change these values before deploying.
CYBER_AGENT_DEMO_PASSWORD=ChangeMe123!
CYBER_AGENT_AUTH_SECRET=please-change-this-random-secret

# Backend API
CYBER_AGENT_CONFIG_PATH=config/config.example.yaml
CYBER_AGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Chat persistence. Default is local SQLite: data/runtime/cyber_agent.db
# Production example: postgresql+psycopg://cyber_agent:change_me@postgres:5432/cyber_agent
CYBER_AGENT_DATABASE_URL=sqlite:///data/runtime/cyber_agent.db

# Auth
CYBER_AGENT_DEMO_PASSWORD=ChangeMe123!
CYBER_AGENT_AUTH_SECRET=change-me-to-a-long-random-secret

# Vue frontend
VITE_API_BASE_URL=http://127.0.0.1:8000
